#!/usr/bin/env bash

set -euo pipefail

cd "$(dirname "$0")/.."

# Mark the necessary Go modules as private to avoid Go's proxy
export GOPRIVATE="${GOPRIVATE:+$GOPRIVATE,}github.com/gumnut-ai/photos-sdk-go,github.com/stainless-sdks/photos-go"

REPLACEMENT="${1:-"../Gumnut-go"}"
echo "==> Replacing Go SDK with $REPLACEMENT"
go mod edit -replace github.com/gumnut-ai/photos-sdk-go="$REPLACEMENT"
go mod tidy -e
